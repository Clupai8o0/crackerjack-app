# Supabase — get from project settings > API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only (never prefix with EXPO_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Sentry — get from project settings > DSN
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@YOUR_ORG.ingest.sentry.io/YOUR_PROJECT_ID
SENTRY_AUTH_TOKEN=YOUR_SENTRY_AUTH_TOKEN

# PostHog — get from project settings
EXPO_PUBLIC_POSTHOG_API_KEY=phc_YOUR_KEY
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Google Maps (for react-native-maps + Places)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_KEY

# Razorpay (test keys until Phase 4)
EXPO_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# App env
EXPO_PUBLIC_APP_ENV=development
